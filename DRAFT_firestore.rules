rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    // Explicitly supporting anonymous public access for ARG Guestbook
    match /comments/{commentId} {
      allow list: if (resource.data.isSecretMode == true || resource.data.isSecretMode == false);
      allow get: if isValidId(commentId) && (resource.data.isSecretMode == true || resource.data.isSecretMode == false);
      
      allow create: if isValidId(commentId) && isValidComment(request.resource.data);
      allow update: if false;
      allow delete: if false;
    }

    // Primitives
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function isValidComment(data) {
      return data.keys().hasAll(['name', 'text', 'isSecretMode', 'createdAt'])
        && data.keys().size() == 4
        && data.name is string
        && data.name.size() <= 30
        && data.text is string
        && data.text.size() <= 250
        && data.isSecretMode is bool
        && data.createdAt == request.time;
    }
  }
}
